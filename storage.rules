rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /clientes/{clienteSlug}/produtos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
